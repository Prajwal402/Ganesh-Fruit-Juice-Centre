{
    "version": 2,
    "functions": {
        "server.js": {
            "runtime": "@vercel/node"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server.js"
        },
        {
            "source": "/admin/login",
            "destination": "/server.js"
        },
        {
            "source": "/admin/logout",
            "destination": "/server.js"
        },
        {
            "source": "/admin",
            "destination": "/admin.html"
        },
        {
            "source": "/(.*\\.(jpg|jpeg|webp|png|css|js|ico|txt))",
            "destination": "/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}