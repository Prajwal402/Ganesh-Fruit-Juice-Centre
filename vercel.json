{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api"
        },
        {
            "source": "/admin/login",
            "destination": "/api"
        },
        {
            "source": "/admin/logout",
            "destination": "/api"
        },
        {
            "source": "/admin",
            "destination": "/admin.html"
        },
        {
            "source": "/:path*",
            "destination": "/index.html"
        }
    ]
}